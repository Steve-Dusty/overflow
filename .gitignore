public/waymo_data/**/*.parquet
public/waymo_data/manifest.json

# E2E raw data (downloaded TFRecords, can be large)
data/e2e_raw/
data/e2e_compact/
# Keep the committed sample:
!data_tools/sample_e2e.json

# Scan temp
scripts/_scan_tmp/

