VITE_OVERFLOW_H100_ENDPOINT=https://inference.overflow.dev/v1/predict
VITE_OVERFLOW_API_KEY=
VITE_OVERFLOW_MODEL=qwen2.5-72b

# OpenAI key for the natural-language scenario generator (src/utils/scenarioAI.ts)
VITE_OPENAI_API_KEY=

# ── Sentry (error monitoring + performance tracing) ──────────────────
# Browser SDK DSN (public). Leave empty to disable monitoring entirely.
VITE_SENTRY_DSN=
# Source-map upload at build time (never exposed to the client bundle):
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional release name:
# VITE_SENTRY_RELEASE=

# ── Overflow backend (instrumented OpenAI proxy + Sentry tunnel) ─────
VITE_API_BASE=http://localhost:8787
VITE_SENTRY_TUNNEL=http://localhost:8787/api/tunnel

# ── ArmorIQ (runtime intent verification for agents) ─────────────────
# SECRET api key from platform.armoriq.ai — server-side only, never VITE_-prefixed.
# Empty ⇒ ArmorIQ is dormant (proxy allows-all, agent runs in shadow mode).
ARMORIQ_API_KEY=
ARMORIQ_AGENT_ID=overflow-safety-agent
ARMORIQ_USER_ID=overflow
ARMORIQ_CONTEXT_ID=default
ARMORIQ_MODE=monitor

# ── AgentSpan (durable execution — agentspan.ai) ─────────────────────
# Runtime auto-starts locally at http://localhost:6767; agents reuse OPENAI_API_KEY
# (overflow keeps it in server/.env). Set these only for AgentSpan Cloud (Orkes):
AGENTSPAN_SERVER_URL=http://localhost:6767
AGENTSPAN_API_KEY=
AGENTSPAN_API_SECRET=
AGENTSPAN_MODEL=
AGENTSPAN_AUTO_APPROVE=1
AGENTSPAN_HITL=0

# ── Band (cross-agent coordination — band.ai) ───────────────────────
# Platform key (band_u_...) from app.band.ai. Per-agent UUIDs → band_agent_config.yaml.
BAND_API_KEY=
